{
  "name": "roxabi-talks",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=24"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd packages/ui build && bun run --cwd apps/web build",
    "typecheck": "bun run --cwd apps/web typecheck",
    "lint": "bunx biome lint .",
    "format": "bunx biome check --write ."
  },
  "devDependencies": {
    "lefthook": "^2.1.4"
  },
  "dependencies": {
    "@fontsource/chakra-petch": "^5.2.7",
    "vercel": "^50.37.1"
  }
}
