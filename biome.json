{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "assist": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": "warn",
        "noExcessiveLinesPerFunction": "warn",
        "useSimplifiedLogicExpression": "warn",
        "noImplicitCoercions": "warn",
        "noUselessUndefined": "warn"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useConst": "error",
        "useImportType": "error",
        "useFilenamingConvention": {
          "level": "error",
          "options": { "filenameCases": ["camelCase"] }
        }
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn",
        "noExtraNonNullAssertion": "warn",
        "useIterableCallbackReturn": "warn",
        "noNonNullAssertedOptionalChain": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      },
      "nursery": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 500
          }
        }
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "es5"
    }
  },
  "css": {
    "parser": {
      "cssModules": true
    },
    "linter": {
      "enabled": false
    }
  },
  "overrides": [
    {
      "includes": ["apps/api/**"],
      "linter": {
        "rules": {
          "style": {
            "useImportType": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/e2e/**",
        "**/.claude/skills/**",
        "**/scripts/**",
        "**/tools/**"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "info",
            "noExcessiveCognitiveComplexity": "info"
          },
          "nursery": {
            "noExcessiveLinesPerFile": "off"
          }
        }
      }
    },
    {
      "includes": ["**/components/**/*.tsx"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": {
              "level": "error",
              "options": { "filenameCases": ["PascalCase"], "strictCase": false }
            }
          }
        }
      }
    },
    {
      "includes": ["**/components/presentation/**", "**/routes/talks/**"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "info",
            "noExcessiveLinesPerFunction": "info"
          },
          "suspicious": {
            "noArrayIndexKey": "info"
          },
          "style": {
            "noNonNullAssertion": "info"
          }
        }
      }
    },
    {
      "includes": ["**/routes/**"],
      "linter": {
        "rules": {
          "style": { "useFilenamingConvention": "off" }
        }
      }
    },
    {
      "includes": [".claude/**"],
      "linter": {
        "rules": {
          "style": { "useFilenamingConvention": "off" }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/.next",
      "!**/.turbo",
      "!**/*.min.js",
      "!**/coverage",
      "!**/.source",
      "!**/.output",
      "!**/.nitro",
      "!**/.content-collections",
      "!**/routeTree.gen.ts",
      "!**/src/paraglide",
      "!**/project.inlang",
      "!**/*.css",
      "!**/playwright-report",
      "!**/test-results",
      "!**/reports/licenses.json",
      "!**/.vercel",
      "!**/e2e/.auth"
    ]
  }
}
